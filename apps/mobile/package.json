{
  "name": "@michelin/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "android": "expo start--android ",
    "build": "expo export --platform android --output-dir dist/android && expo export --platform ios --output-dir dist/ios",
    "dev": "expo start",
    "ios": "expo start--ios ",
    "lint": "eslint .",
    "start": "expo start",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(\\.pnpm|(jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|@michelin/.*))"
    ]
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@michelin/api-client": "workspace:*",
    "@michelin/contracts": "workspace:*",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "expo": "~54.0.35",
    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@expo/metro-config": "~54.0.14",
    "@michelin/config-eslint": "workspace:*",
    "@michelin/config-typescript": "workspace:*",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.1",
    "jest": "^29.0.0",
    "jest-circus": "^29.0.0",
    "jest-expo": "^56.0.5",
    "jest-runtime": "^29.0.0",
    "typescript": "5.9.3"
  }
}
