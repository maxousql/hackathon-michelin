{
  "name": "@michelin/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "android": "expo start --android",
    "build": "expo export --platform android --output-dir dist/android && expo export --platform ios --output-dir dist/ios",
    "dev": "expo start",
    "ios": "expo start --ios",
    "lint": "eslint .",
    "start": "expo start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@michelin/api-client": "workspace:*",
    "@michelin/contracts": "workspace:*",
    "expo": "~56.0.11",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "@expo/metro-config": "56.0.14",
    "@michelin/config-eslint": "workspace:*",
    "@michelin/config-typescript": "workspace:*",
    "@types/node": "^22.19.0",
    "@types/react": "19.2.17",
    "babel-preset-expo": "56.0.15",
    "eslint": "^9.39.1",
    "typescript": "5.9.3"
  }
}
